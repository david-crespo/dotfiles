{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(tokei:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(time:*)",
      "Bash(timeout:*)",
      "Bash(hyperfine:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(jj help:*)",
      "Bash(jj log:*)",
      "Bash(jj evolog:*)",
      "Bash(jj diff:*)",
      "Bash(jj op log:*)",
      "Bash(jj op show:*)",
      "Bash(jj status:*)",
      "Bash(jj show:*)",
      "Bash(jj file show:*)",
      "Bash(jj file list:*)",
      "Bash(jj file annotate:*)",
      "Bash(jj new:*)",
      "Bash(jj desc:*)",
      "Bash(jj describe:*)",
      "Bash(jj commit:*)",
      "Bash(jj bookmark list:*)",
      "Bash(jj config list:*)",
      "Bash(jj config get:*)",
      "Bash(jj config path:*)",
      "Bash(jj dt:*)",
      "Bash(jj dts:*)",
      "Bash(jj st:*)",
      "Bash(jj workspace update-stale)",
      "Bash(cargo tree:*)",
      "Bash(cargo info:*)",
      "Bash(cargo search:*)",
      "Bash(cargo metadata:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo nextest run:*)",
      "Bash(cargo xfmt:*)",
      "Bash(cargo xtask openapi generate:*)",
      "Bash(npm run check)",
      "Bash(npm run fmt)",
      "Bash(npm run build)",
      "Bash(npm run build:react-router)",
      "Bash(npm ls:*)",
      "Bash(npm info:*)",
      "Bash(npm outdated:*)",
      "Bash(deno info:*)",
      "Bash(deno fmt:*)",
      "Bash(deno lint:*)",
      "Bash(deno check:*)",
      "Bash(go doc:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh search:*)",
      "Bash(gh-api-read *)",
      "Bash(jq:*)",
      "Bash(tmux new-session:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tviz:*)",
      "Bash(~/.claude/skills/coach/gh-activity.sh:*)",
      "Bash(~/.claude/skills/session-history/claude-sessions.sh:*)",
      "Bash(obsidian-notes:*)",
      "Bash(sw_vers:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(man:*)",
      "Bash(tldr:*)",
      "Bash(aipr tracking:*)",
      "Bash(aipr discussion:*)",
      "Bash(turnstile review list:*)",
      "Bash(turnstile reviews list:*)",
      "Bash(turnstile reviewer list:*)",
      "Bash(turnstile application get:*)",
      "Bash(turnstile application summaries:*)",
      "Bash(turnstile applicant get:*)",
      "Bash(turnstile triage --reviewer:*)",
      "Bash(brew info:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.oxide.computer)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:shiki.style)",
      "WebFetch(domain:docs.jj-vcs.dev)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:support.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(curl:*)",
      "Bash(tviz update:*)",
      "Bash(jj restore:*)",
      "Bash(jj squash:*)",
      "Bash(jj rebase:*)",
      "Bash(jj resolve:*)",
      "Bash(turnstile triage add:*)"
    ],
    "additionalDirectories": [
      "../omicron",
      "~/oxide/omicron",
      "../console",
      "~/oxide/console"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jjw-cmd create"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/claude-worktree-remove"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.ts"
  },
  "enabledPlugins": {
    "ast-grep@ast-grep-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "eng@oxide": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "oxide": {
      "source": {
        "source": "github",
        "repo": "oxidecomputer/claude-plugins"
      }
    }
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true
}
